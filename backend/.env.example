# ─────────────────────────────────────────────────────────────
# Product Discovery API — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────
# OpenAI API Key — required for the /api/ask endpoint
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ── Optional (with defaults) ─────────────────────────────────
# Server port (default: 4000)
PORT=4000

# Node environment: "development" | "production" (default: development)
NODE_ENV=development

# Rate limiting for /api/ask (default: 15 requests per 60 seconds)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=15

# Max request body size (default: 50kb)
BODY_SIZE_LIMIT=50kb
